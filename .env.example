# Database
DATABASE_URL="file:./prisma/dev.db"

# Auth secrets — generate with: openssl rand -base64 32
JWT_ACCESS_SECRET="change-me-access-secret-32-chars"
JWT_REFRESH_SECRET="change-me-refresh-secret-32-chars"
APP_QR_SECRET="change-me-qr-secret-32-chars"

# UMI Master Admin password (for /umi/admin)
UMI_ADMIN_PASSWORD="change-me-strong-password"

# Tenant seed credentials (used by prisma/seed.ts — change before first deploy)
EGR_ADMIN_EMAIL="admin@elgranribera.mx"
EGR_ADMIN_PASSWORD="change-me-strong-password"
KLC_ADMIN_EMAIL="admin@kalalacafe.mx"
KLC_ADMIN_PASSWORD="change-me-strong-password"

# Apple Wallet (requires Apple Developer account — $99/año)
# https://developer.apple.com/documentation/walletpasses
APPLE_TEAM_ID="XXXXXXXXXX"
APPLE_PASS_TYPE_ID="pass.co.umicash.loyalty"
APPLE_CERT_PATH="./passes/apple/certificates/signerCert.pem"
APPLE_KEY_PATH="./passes/apple/certificates/signerKey.pem"
APPLE_KEY_PASSPHRASE=""
APPLE_WWDR_PATH="./passes/apple/certificates/wwdr.pem"
APPLE_APN_KEY_ID="XXXXXXXXXX"
APPLE_APN_KEY_PATH="./passes/apple/certificates/apn_key.p8"
APPLE_APN_BUNDLE_ID="pass.co.umicash.loyalty"

# Google Wallet (requires Google Cloud project + Wallet API enabled)
# https://developers.google.com/wallet/retail/loyalty-cards
GOOGLE_SERVICE_ACCOUNT_EMAIL="wallet@your-project.iam.gserviceaccount.com"
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nXXXX\n-----END RSA PRIVATE KEY-----"
GOOGLE_WALLET_ISSUER_ID="1234567890123456789"
GOOGLE_WALLET_CLASS_ID="umicash_loyalty_v1"

# Public URL of this app (for wallet web service + pass images)
NEXT_PUBLIC_APP_URL="https://cash.umiconsulting.co"

# Email (optional - Resend)
RESEND_API_KEY=
EMAIL_FROM=Umi Cash <noreply@umiconsulting.co>
