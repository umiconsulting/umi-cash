          {
            "type": "command",
            "command": "INPUT=$(cat); FILE=$(echo \"$INPUT\" | jq -r '.tool_input.file_path // empty'); TOOL=$(echo \"$INPUT\" | jq -r '.tool_name // \"Edit\"'); if [ -n \"$FILE\" ] && echo \"$FILE\" | grep -q \"umi-cash\"; then LOG_DIR=\"/Users/469096/Documents/dev/Projects/umi/umi-cash/logs\"; mkdir -p \"$LOG_DIR\"; LOG_FILE=\"$LOG_DIR/$(date +%Y-%m-%d).md\"; if [ \"$TOOL\" = \"Write\" ]; then ACTION=\"Created\"; else ACTION=\"Updated\"; fi; REL=$(echo \"$FILE\" | sed 's|.*/umi-cash/||'); FNAME=$(basename \"$FILE\"); DIR=$(dirname \"$REL\"); if [ ! -f \"$LOG_FILE\" ]; then printf '# %s\\n\\n## Cambios del dia\\n\\n' \"$(date +%Y-%m-%d)\" > \"$LOG_FILE\"; fi; if [ \"$DIR\" = \".\" ]; then printf -- '- **%s** %s `%s`\\n' \"$(date +%H:%M)\" \"$ACTION\" \"$FNAME\" >> \"$LOG_FILE\"; else printf -- '- **%s** %s `%s` en `%s`\\n' \"$(date +%H:%M)\" \"$ACTION\" \"$FNAME\" \"$DIR\" >> \"$LOG_FILE\"; fi; fi 2>/dev/null || true",
