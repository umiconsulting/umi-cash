passes/apple/certificates/*.pem
passes/apple/certificates/*.p8
passes/apple/certificates/*.p12

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# misc
.DS_Store
*.pem
.vercel
.env*.local
